@page "/"

<PageTitle>Currículo | Dev .NET</PageTitle>

<div class="container py-4">
    <div class="row">

        <div class="col-lg-4">
            <div class="text-center p-4 bg-light rounded-3 mb-4">

                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix"
                     class="rounded-circle mb-3"
                     width="120" />

                <h3>Claudio Martins Camilo</h3>

                <p class="text-muted">
                    Desenvolvedor Fullstack
                </p>

            </div>
        </div>

        <div class="col-lg-8">

            <h2 class="mb-4">
                Experiência Profissional
            </h2>

            @foreach (var exp in MinhasExperiencias)
            {
                <ExperienciaCard Dados="exp" />
            }

            <h2 class="mt-5">
                Habilidades Técnicas
            </h2>

            <ul class="list-group mt-3">
                <li class="list-group-item">C# .NET</li>
                <li class="list-group-item">Blazor</li>
                <li class="list-group-item">SQL Server</li>
                <li class="list-group-item">Git e GitHub</li>
                <li class="list-group-item">Suporte Técnico</li>
            </ul>

        </div>

    </div>
</div>

@code {

    private List<Experiencia> MinhasExperiencias = new()
    {
        new Experiencia
        {
            Empresa = "WF Tecnologia Científica",
            Cargo = "Analista de Sistemas / Suporte Técnico",
            Inicio = "2024",
            Descricao = "Atuação com suporte técnico, sistemas e soluções em tecnologia."
        },

        new Experiencia
        {
            Empresa = "Projetos Independentes",
            Cargo = "Desenvolvedor Freelancer",
            Inicio = "2023",
            Fim = "2024",
            Descricao = "Desenvolvimento de sites e manutenção de aplicações."
        }
    };

}